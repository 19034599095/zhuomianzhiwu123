.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.page-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #999999;
}

.tabs {
  display: flex;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.1);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #666666;
}

.tab-item.active .tab-text {
  color: #ffffff;
}

.my-rank {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 152, 0, 0.2);
}

.rank-badge {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.rank-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

.rank-avatar {
  width: 80rpx;
  height: 80rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.avatar-emoji {
  font-size: 40rpx;
}

.my-info {
  flex: 1;
}

.my-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.my-score {
  font-size: 26rpx;
  color: #FF9800;
}

.my-level {
  font-size: 24rpx;
  color: #FFC107;
  background: rgba(255, 255, 255, 0.8);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.ranking-list {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.1);
  margin-bottom: 30rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.3s ease;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-item.top {
  background: #fafafa;
}

.rank-item.my-item {
  background: #E8F5E9;
}

.rank-position {
  width: 48rpx;
  display: flex;
  justify-content: center;
  margin-right: 16rpx;
}

.medal {
  font-size: 36rpx;
}

.rank-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #999999;
}

.rank-info {
  flex: 1;
  margin-right: 16rpx;
}

.rank-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 4rpx;
}

.rank-score {
  font-size: 24rpx;
  color: #666666;
}

.rank-plant {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.rank-level {
  font-size: 24rpx;
  color: #999999;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.empty-ranking {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.1);
  margin-bottom: 30rpx;
}

.empty-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

.share-section {
  text-align: center;
}

.share-btn {
  width: 100%;
  padding: 28rpx;
  font-size: 32rpx;
}
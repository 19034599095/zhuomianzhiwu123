.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.page-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #999999;
}

.garden-stats {
  display: flex;
  justify-content: space-around;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.1);
  margin-bottom: 30rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.current-plant {
  margin-bottom: 30rpx;
}

.plant-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(76, 175, 80, 0.15);
}

.plant-card.wilted {
  opacity: 0.7;
  background: #f5f5f5;
}

.plant-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.plant-emoji-large {
  font-size: 120rpx;
  margin-right: 24rpx;
}

.plant-info {
  flex: 1;
}

.plant-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.plant-stage-badge {
  font-size: 26rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.plant-progress {
  background: #f8faf6;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.progress-section {
  margin-bottom: 20rpx;
}

.progress-section:last-child {
  margin-bottom: 0;
}

.progress-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
  display: block;
}

.progress-bar-large {
  height: 20rpx;
  background: #e0e0e0;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill-large {
  height: 100%;
  background: linear-gradient(90deg, #81C784 0%, #4CAF50 100%);
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.progress-fill-bloom {
  height: 100%;
  background: linear-gradient(90deg, #E1BEE7 0%, #9C27B0 100%);
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #999999;
}

.plant-status {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.status-item {
  flex: 1;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.status-item.active {
  background: #E8F5E9;
}

.status-icon {
  font-size: 36rpx;
  display: block;
  margin-bottom: 8rpx;
}

.status-text {
  font-size: 26rpx;
  color: #666666;
}

.no-plant {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.1);
  margin-bottom: 30rpx;
}

.no-plant-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.no-plant-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.no-plant-hint {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-bottom: 30rpx;
}

.history-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.history-list {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.1);
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.record-emoji {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.record-info {
  flex: 1;
}

.record-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.record-stage {
  font-size: 24rpx;
  color: #4CAF50;
  display: block;
  margin-bottom: 4rpx;
}

.record-date {
  font-size: 22rpx;
  color: #999999;
}

.record-status {
  font-size: 40rpx;
}

.record-status.bloomed {
  animation: pulse 1s infinite;
}

.empty-history {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.1);
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.garden-tips {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 24rpx;
  padding: 24rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.tips-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tip {
  font-size: 24rpx;
  color: #666666;
  background: #ffffff;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.1); }
}
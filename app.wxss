page {
  background: linear-gradient(180deg, #f8faf6 0%, #e8f5e9 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.1);
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.3);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background: #f0f0f0;
  color: #666666;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
}

.text-primary {
  color: #4CAF50;
}

.text-secondary {
  color: #999999;
}

.text-success {
  color: #66BB6A;
}

.text-warning {
  color: #FFC107;
}

.text-danger {
  color: #EF5350;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.plant-emoji {
  font-size: 120rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.8;
    transform: scale(1.05);
  }
}

@keyframes waterDrop {
  0% {
    transform: translateY(-20rpx);
    opacity: 1;
  }
  100% {
    transform: translateY(40rpx);
    opacity: 0;
  }
}

@keyframes shake {
  0%, 100% {
    transform: translateX(0);
  }
  25% {
    transform: translateX(-5rpx);
  }
  75% {
    transform: translateX(5rpx);
  }
}

.animate-pulse {
  animation: pulse 1.5s infinite;
}

.animate-water {
  animation: waterDrop 0.8s ease-in-out;
}

.animate-shake {
  animation: shake 0.5s ease-in-out;
}

.progress-bar {
  height: 16rpx;
  background: #e8f5e9;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #81C784 0%, #4CAF50 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.water-drop {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  background: #64B5F6;
  border-radius: 50%;
  animation: waterDrop 0.8s ease-in-out forwards;
}

.crit-effect {
  position: absolute;
  font-size: 48rpx;
  font-weight: bold;
  color: #FFD700;
  animation: floatUp 1s ease-out forwards;
}

@keyframes floatUp {
  0% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-60rpx) scale(1.5);
  }
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  margin: 40rpx;
  max-width: 600rpx;
  text-align: center;
}

.game-container {
  position: relative;
  width: 100%;
  height: 300rpx;
  background: linear-gradient(180deg, #87CEEB 0%, #98FB98 100%);
  border-radius: 24rpx;
  overflow: hidden;
}

.water-target {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  background: #FF6B6B;
  border-radius: 50%;
  text-align: center;
  line-height: 80rpx;
  font-size: 40rpx;
  animation: pulse 0.8s infinite;
}

.question-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.1);
}

.option-btn {
  width: 100%;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #e8f5e9;
  border-radius: 16rpx;
  background: #ffffff;
  font-size: 30rpx;
  text-align: left;
  transition: all 0.3s ease;
}

.option-btn:active {
  background: #e8f5e9;
}

.option-btn.correct {
  background: #C8E6C9;
  border-color: #4CAF50;
}

.option-btn.wrong {
  background: #FFCDD2;
  border-color: #EF5350;
}